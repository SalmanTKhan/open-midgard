{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-win32",
      "displayName": "VS2022 Win32",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "vs2022-x64",
      "displayName": "VS2022 x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build64",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "mingw-qt-x64",
      "displayName": "MinGW Qt x64",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build-mingw-preset",
      "environment": {
        "PATH": "C:/Qt/Tools/mingw1310_64/bin;C:/Qt/6.11.0/mingw_64/bin;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "RO_ENABLE_DEV_DEPLOY": "ON",
        "RO_ENABLE_QT6_UI_SPIKE": "ON",
        "RO_QT_UI_SPIKE_DEFAULT_ENABLED": "ON",
        "RO_QT_ROOT": "C:/Qt/6.11.0/mingw_64"
      }
    },
    {
      "name": "linux-qt-vulkan",
      "displayName": "Linux Qt Vulkan",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux-qt-vulkan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "RO_ENABLE_DEV_DEPLOY": "OFF",
        "RO_ENABLE_QT6_UI": "ON",
        "RO_QT_UI_DEFAULT_ENABLED": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
