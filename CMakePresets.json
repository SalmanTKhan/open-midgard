    },
    {
      "name": "build-release",
      "configurePreset": "vs2022-win32",
      "configuration": "Release"
    },
    {
      "name": "build-debug-x64",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "build-release-x64",
      "configurePreset": "vs2022-x64",
      "configuration": "Release"
    },
    {
      "name": "build-mingw-qt-x64",
      "configurePreset": "mingw-qt-x64"
    },
    {
      "name": "build-linux-qt-vulkan",
      "configurePreset": "linux-qt-vulkan"
