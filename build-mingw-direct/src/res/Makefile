	cd /d D:\Spel\RoRebuild\Ragnarok___Win32_HighPriest2008_Release\build-mingw-direct && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles\Makefile.cmake 0
